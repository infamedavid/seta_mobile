<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme.SetaMobile" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar" tools:targetApi="23">false</item>
    </style>

    <style name="Theme.SetaMobile.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#F4EEF6</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_seta_splash</item>
        <item name="postSplashScreenTheme">@style/Theme.SetaMobile</item>
    </style>

</resources>